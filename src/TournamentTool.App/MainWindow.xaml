<Window x:Class="TournamentTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:selectable="clr-namespace:TournamentTool.ViewModels.Selectable;assembly=TournamentTool.ViewModels"
        xmlns:viewModels="clr-namespace:TournamentTool.ViewModels;assembly=TournamentTool.ViewModels"
        xmlns:buttons="clr-namespace:TournamentTool.App.Components.Buttons"
        xmlns:views="clr-namespace:TournamentTool.App.Views"
        xmlns:controls="clr-namespace:TournamentTool.App.Components.Controls"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        mc:Ignorable="d"
        Closed="OnClosed"
        Width="1082"
        Height="628"
        Title="Tournament Tool"
        BorderThickness="0.75"
        BorderBrush="Black"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        MinWidth="1082"
        MinHeight="628"
        MaxHeight="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenHeight}}"
        Background="#383A3f">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      CaptionHeight="24"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="{x:Type Panel}"
               x:Key="WindowMainPanelStyle">
            <Setter Property="Margin"
                    Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}"
                             Value="Maximized">
                    <Setter Property="Margin"
                            Value="7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Style="{StaticResource WindowMainPanelStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="29" />
            <RowDefinition />
            <RowDefinition Height="27" />
        </Grid.RowDefinitions>

        <!--HEADER-->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Background="#000D14">
                <CheckBox WindowChrome.IsHitTestVisibleInChrome="True"
                          IsChecked="{Binding IsHamburgerMenuOpen}"
                          HorizontalAlignment="Left">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <Grid x:Name="RootElement"
                                              Width="30"
                                              Height="30"
                                              Background="#000D14">
                                            <Border Width="20"
                                                    Height="22"
                                                    CornerRadius="5">
                                                <Viewbox>
                                                    <Path Fill="White"
                                                          Stretch="Uniform"
                                                          Data="M 0 7.5 L 0 12.5 L 50 12.5 L 50 7.5 Z M 0 22.5 L 0 27.5 L 50 27.5 L 50 22.5 Z M 0 37.5 L 0 42.5 L 50 42.5 L 50 37.5 Z" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="RootElement"
                                                        Property="Background"
                                                        Value="#3e3e3e" />
                                            </Trigger>
                                            <Trigger Property="IsChecked"
                                                     Value="True">
                                                <Setter TargetName="RootElement"
                                                        Property="Background"
                                                        Value="#252525" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
            </Grid>

            <Grid Grid.Column="1"
                  Background="#000D14">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="TournamentTool by FaNim"
                               FontWeight="Bold"
                               HorizontalAlignment="Left"
                               FontSize="14"
                               Foreground="LightCyan" />
                    <TextBlock Text="{Binding VersionText}"
                               FontWeight="Bold"
                               FontSize="10"
                               HorizontalAlignment="Left"
                               Margin="5 4 0 0"
                               Foreground="LightCyan" />
                    <Border Visibility="{Binding NewUpdate, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="Red"
                            CornerRadius="10"
                            Width="19"
                            Height="19"
                            Padding="1"
                            Margin="5 0 0 0">
                        <TextBlock Foreground="White"
                                   FontWeight="Bold"
                                   Padding="0"
                                   Text="!"
                                   FontSize="18"
                                   Margin="5 -5" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <buttons:ButtonTaskbar Width="30"
                                           Height="30"
                                           FontSize="20"
                                           WindowChrome.IsHitTestVisibleInChrome="True"
                                           HorizontalAlignment="Right"
                                           ColorBrush="#5a5d65"
                                           Content="-"
                                           Padding="2"
                                           Click="MinimizeButtonsClick" />
                    <buttons:ButtonTaskbar Width="30"
                                           Height="30"
                                           FontSize="20"
                                           WindowChrome.IsHitTestVisibleInChrome="True"
                                           HorizontalAlignment="Right"
                                           ColorBrush="#ff000f"
                                           Content="X"
                                           Padding="1"
                                           Click="ExitButtonClick" />
                </StackPanel>
            </Grid>
        </Grid>

        <!--BODY-->
        <ContentControl Grid.Row="1"
                        Content="{Binding NavigationService.SelectedView}" />

        <!-- CONSOLE -->
        <ContentControl Grid.Row="1"
                        Visibility="{Binding Console.IsDockedConsoleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <views:ConsoleView DataContext="{Binding Console}" />
        </ContentControl>
        
        <!-- NOTIFICATION PANEL -->
        <ContentControl Grid.Row="1"
                        Visibility="{Binding NotificationPanel.IsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <views:NotificationPanelView DataContext="{Binding NotificationPanel}"
                                         OnHideCommand="{Binding HidePanelCommand}" />
        </ContentControl>

        <controls:HamburgerMenu Grid.Row="1"
                                IsOpen="{Binding IsHamburgerMenuOpen}">
            <controls:HamburgerMenu.HamburgerContent>
                <Grid>
                    <StackPanel>
                        <controls:HamburgerMenuItem Text="Controller"
                                                    Command="{Binding SelectViewModelCommand}"
                                                    CommandParameter="Controller"
                                                    Foreground="LimeGreen"
                                                    IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:ControllerViewModel}}"
                                                    GroupName="MenuItem" />
                        <controls:HamburgerMenuItem Text="Presets"
                                                    Command="{Binding SelectViewModelCommand}"
                                                    CommandParameter="Presets"
                                                    IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:PresetManagerViewModel}}"
                                                    GroupName="MenuItem" />
                        <controls:HamburgerMenuItem Text="Whitelist"
                                                    Command="{Binding SelectViewModelCommand}"
                                                    CommandParameter="Whitelist"
                                                    IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:PlayerManagerViewModel}}"
                                                    GroupName="MenuItem" />
                        <controls:HamburgerMenuItem Text="Leaderboard"
                                                    Command="{Binding SelectViewModelCommand}"
                                                    CommandParameter="Leaderboard"
                                                    IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:LeaderboardPanelViewModel}}"
                                                    GroupName="MenuItem" />
                        <controls:HamburgerMenuItem Text="Scene Config"
                                                    Command="{Binding SelectViewModelCommand}"
                                                    CommandParameter="SceneManagement"
                                                    IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:SceneManagementViewModel}}"
                                                    GroupName="MenuItem" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <Grid>
                            <controls:HamburgerMenuItem Text="Updates"
                                                        Command="{Binding SelectViewModelCommand}"
                                                        CommandParameter="Updates"
                                                        IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:UpdatesViewModel}}"
                                                        GroupName="MenuItem" />
                            <Border Visibility="{Binding NewUpdate, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="Red"
                                    CornerRadius="10"
                                    Width="19"
                                    Height="19"
                                    Padding="1"
                                    Margin="35 5 0 0">
                                <TextBlock Foreground="White"
                                           FontWeight="Bold"
                                           Padding="0"
                                           Text="!"
                                           FontSize="18"
                                           Margin="5 -5" />
                            </Border>
                        </Grid>
                        <controls:HamburgerMenuItem Text="Settings"
                                                    Command="{Binding SelectViewModelCommand}"
                                                    CommandParameter="Settings"
                                                    IsChecked="{Binding NavigationService.SelectedView, Mode=OneWay, Converter={StaticResource TypeToBoolConverter}, ConverterParameter={x:Type selectable:SettingsViewModel}}"
                                                    GroupName="MenuItem" />
                    </StackPanel>
                </Grid>
            </controls:HamburgerMenu.HamburgerContent>
        </controls:HamburgerMenu>

        <!-- STATUS BAR -->
        <ContentPresenter Grid.Row="2"
                          Content="{Binding StatusBar}" />

        <Border Grid.Row="1"
                Grid.RowSpan="2"
                Visibility="{Binding IsWindowBlocked, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="Black"
                Opacity="0.5" />
    </Grid>
</Window>