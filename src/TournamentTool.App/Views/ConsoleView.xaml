<UserControl x:Class="TournamentTool.App.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TournamentTool.App.Views"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:viewModels="clr-namespace:TournamentTool.ViewModels;assembly=TournamentTool.ViewModels"
             xmlns:entities="clr-namespace:TournamentTool.ViewModels.Entities;assembly=TournamentTool.ViewModels"
             xmlns:buttons="clr-namespace:TournamentTool.App.Components.Buttons"
             xmlns:controls="clr-namespace:TournamentTool.App.Components.Controls"
             xmlns:logging="clr-namespace:TournamentTool.ViewModels.Logging;assembly=TournamentTool.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=logging:ConsoleViewModel}"
             d:DesignHeight="576"
             d:DesignWidth="1024"
             BorderThickness="0.75"
             BorderBrush="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>
        
        <Border Grid.RowSpan="2" Background="Black"
                Opacity="0.85" />

        <controls:ConsoleLogsView Grid.Row="0"
                                  ItemsSource="{Binding Logs}"
                                  Margin="2 0 0 0" />

        <Grid Grid.Row="1"
              Background="#191919"
              Opacity="0.8">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <buttons:ButtonNormal VerticalAlignment="Center"
                                      ContentText="Clear"
                                      OnCommand="{Binding ClearLogsCommand}"
                                      Width="60"
                                      Height="22" />

                <buttons:ButtonNormal VerticalAlignment="Center"
                                      ContentText="Save"
                                      OnCommand="{Binding SaveLogsCommand}"
                                      Width="60"
                                      Height="22"
                                      Margin="7 0 7 0" />
                
                <buttons:ButtonNormal VerticalAlignment="Center"
                                      ContentText="\/"
                                      OnCommand="{Binding OpenInNewWindowCommand}"
                                      ToolTipService.InitialShowDelay="0"
                                      ToolTipService.ShowDuration="60000"
                                      ToolTip="Open in new window"
                                      Width="30"
                                      Height="22"
                                      Margin="0 0 7 0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
