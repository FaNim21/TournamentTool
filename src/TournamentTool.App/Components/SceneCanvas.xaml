<UserControl x:Class="TournamentTool.App.Components.SceneCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="clr-namespace:Microsoft.Xaml.Behaviors;assembly=Microsoft.Xaml.Behaviors"
             xmlns:controller="clr-namespace:TournamentTool.ViewModels.Selectable.Controller;assembly=TournamentTool.ViewModels"
             xmlns:behaviors="clr-namespace:TournamentTool.App.Components.Behaviors"
             xmlns:obs1="clr-namespace:TournamentTool.ViewModels.Obs;assembly=TournamentTool.ViewModels"
             xmlns:items="clr-namespace:TournamentTool.ViewModels.Obs.Items;assembly=TournamentTool.ViewModels"
             d:DataContext="{d:DesignInstance Type=obs1:Scene}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ContextMenu x:Key="POVContextMenu">
            <MenuItem Header="Info"
                      Command="{Binding DataContext.ShowInfoWindowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                      CommandParameter="{Binding .}"/>
            <MenuItem Header="Refresh"
                      Command="{Binding DataContext.RefreshPOVCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                      CommandParameter="{Binding .}"/>
            <MenuItem Header="Clear"
                      Command="{Binding DataContext.ClearPOVCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding .}"
                      InputGestureText="Ctrl + RMB" />
        </ContextMenu>
    </UserControl.Resources>
    
    <Border Background="Transparent"
            BorderBrush="Black"
            BorderThickness="1">
        <Grid>
            <Canvas Background="#2C2C2C"
                    Width="{Binding CanvasWidth, Mode=OneWay}"
                    Height="{Binding CanvasHeight, Mode=OneWay}"
                    AllowDrop="True"
                    ClipToBounds="True"
                    Focusable="True">
                <ItemsControl ItemsSource="{Binding SceneItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="ContextMenu" Value="{StaticResource POVContextMenu}"/>
                            <Setter Property="Canvas.Left"
                                    Value="{Binding Transform.X, Mode=OneWay}" />
                            <Setter Property="Canvas.Top"
                                    Value="{Binding Transform.Y, Mode=OneWay}" />
                            <Setter Property="Width"
                                    Value="{Binding Transform.Width, Mode=OneWay}" />
                            <Setter Property="Height"
                                    Value="{Binding Transform.Height, Mode=OneWay}" />
                            
                            <Setter Property="Panel.ZIndex"
                                    Value="{Binding ZIndex, Mode=OneWay}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    
                    <ItemsControl.Resources>
                        <DataTemplate DataType="{x:Type items:PointOfView}">
                            <Border Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}, Mode=OneWay}"
                                    Visibility="{Binding IsDisplayed, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                    Width="{Binding Transform.Width, Mode=OneWay}"
                                    Height="{Binding Transform.Height, Mode=OneWay}"
                                    BorderBrush="#1E90FF"
                                    BorderThickness="0.8"
                                    CornerRadius="5"
                                    Drop="PointOfView_Drop"
                                    PreviewMouseLeftButtonDown="PointOfView_PreviewMouseLeftButtonDown"
                                    MouseEnter="PointOfView_MouseEnter"
                                    MouseLeave="PointOfView_MouseLeave"
                                    ContextMenuOpening="Border_ContextMenuOpening">
                                <i:Interaction.Behaviors>
                                    <behaviors:BorderDragDropBehavior DragDataType="{x:Type items:PointOfView}"/>
                                </i:Interaction.Behaviors>
                                <Grid IsHitTestVisible="False">
                                    <TextBlock Text="{Binding SceneItemName, Mode=OneWay}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Top"
                                               FontSize="{Binding DataContext.FontSizeSceneName, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"
                                               Foreground="#E0E0E0" />
                                    <TextBlock Text="{Binding DisplayedPlayer, Mode=OneWay}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding Transform.Width, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource FontSizeConverter}}"
                                               FontWeight="Bold"
                                               Foreground="#373737" />

                                    <Image Width="16"
                                           Height="16"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Left"
                                           Margin="3 0 0 0">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source">
                                                    <Setter.Value>
                                                        <BitmapImage DecodePixelWidth="16"
                                                                     UriSource="/Resources/muted.png" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMuted}"
                                                                 Value="False">
                                                        <Setter Property="Source">
                                                            <Setter.Value>
                                                                <BitmapImage DecodePixelWidth="16"
                                                                             UriSource="/Resources/audio.png" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </Border>
                        </DataTemplate>
                        
                        <DataTemplate DataType="{x:Type items:SceneItemViewModel}">
                            <Border Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}, Mode=OneWay}"
                                    Visibility="{Binding IsDisplayed, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                    Width="{Binding Transform.Width, Mode=OneWay}"
                                    Height="{Binding Transform.Height, Mode=OneWay}"
                                    IsHitTestVisible="False"
                                    Opacity="0.5"
                                    BorderBrush="#1873cc"
                                    BorderThickness="0.8" />
                        </DataTemplate>
                        
                    </ItemsControl.Resources>
                </ItemsControl>
            </Canvas>
        </Grid>
    </Border>
</UserControl>
