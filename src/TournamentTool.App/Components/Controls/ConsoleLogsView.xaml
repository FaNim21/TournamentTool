<controls:VirtualizingItemsControl x:Class="TournamentTool.App.Components.Controls.ConsoleLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:entities="clr-namespace:TournamentTool.ViewModels.Entities;assembly=TournamentTool.ViewModels"
             Background="Transparent"
             BorderThickness="0"
             ScrollViewer.CanContentScroll="True"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Visible"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             VirtualizingPanel.ScrollUnit="Pixel"
             SnapsToDevicePixels="True">
    <controls:VirtualizingItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type entities:LogEntryViewModel}">
            <StackPanel Orientation="Horizontal"
                        Height="18"
                        Margin="0 -1 0 -1">

                <TextBlock Text="{Binding Date, Mode=OneTime}"
                           Width="75"
                           FontSize="12"
                           Foreground="DarkGray"
                           FontWeight="SemiBold" />

                <TextBlock Text="{Binding Type, Mode=OneTime}"
                           Margin="3 0 0 0"
                           FontSize="12"
                           Foreground="{Binding LogLevelColor, Converter={StaticResource StringToBrushConverter}}"
                           FontWeight="SemiBold" />

                <TextBlock Text="{Binding Message, Mode=OneTime}"
                           TextWrapping="Wrap"
                           Margin="0 0 0 0"
                           FontSize="12"
                           Foreground="{Binding LogLevelColor, Converter={StaticResource StringToBrushConverter}}" />
            </StackPanel>
        </DataTemplate>
    </controls:VirtualizingItemsControl.ItemTemplate>
</controls:VirtualizingItemsControl>
