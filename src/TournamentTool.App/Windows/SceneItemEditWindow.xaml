<Window x:Class="TournamentTool.App.Windows.SceneItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TournamentTool.App.Windows"
        xmlns:obs="clr-namespace:TournamentTool.ViewModels.Obs;assembly=TournamentTool.ViewModels"
        xmlns:buttons="clr-namespace:TournamentTool.App.Components.Buttons"
        xmlns:items="clr-namespace:TournamentTool.ViewModels.Obs.Items;assembly=TournamentTool.ViewModels"
        xmlns:obsDomain="clr-namespace:TournamentTool.Domain.Obs;assembly=TournamentTool.Domain"
        xmlns:converters="clr-namespace:TournamentTool.App.Converters"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:TournamentTool.App.Components.Behaviors"
        xmlns:bindings="clr-namespace:TournamentTool.ViewModels.Obs.Bindings;assembly=TournamentTool.ViewModels"
        d:DataContext="{d:DesignInstance Type=obs:SceneItemEditWindowViewModel}"
        mc:Ignorable="d"
        Title="Scene item edit window"
        Height="450"
        Width="800"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        WindowStyle="None">
    <Window.Resources>

        <DataTemplate DataType="{x:Type bindings:BindingPovViewModel}">
            <StackPanel HorizontalAlignment="Stretch">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0 5 0 0">
                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="200"
                              ItemsSource="{Binding Fields}"
                              SelectedItem="{Binding ChosenField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Field"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Field that api is reading data from"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>
                
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0 5 0 0">

                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="200"
                              ItemsSource="{Binding PovNames}"
                              SelectedItem="{Binding ChosenPovName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="POV name"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Binding source pov name (for multiple elements of same source)"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>
                
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type bindings:BindingRankedManagementViewModel}">
            <StackPanel>
                <TextBlock Text="XD" />
            </StackPanel>
        </DataTemplate>

        <!-- Zostalo jako templatka do indexu??????? -->
        <DataTemplate DataType="{x:Type items:BrowserItemViewModel}">
            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Visibility="{Binding DataContext.IsUsingIndex, Converter={StaticResource BoolToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0 10 0 5">
                    <TextBox TextWrapping="Wrap"
                             Width="120"
                             Height="20"
                             Text="{Binding DataContext.Index, RelativeSource={RelativeSource AncestorType=Window}}"
                             Background="#9E9E9E"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top">
                        <b:Interaction.Behaviors>
                            <behaviors:NumericTextBoxBehavior AllowNegative="False" />
                        </b:Interaction.Behaviors>
                    </TextBox>
                    <TextBlock Text="Position"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Binding position (for list/array of elements, 1-based indexing)"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <Border BorderThickness="1"
            BorderBrush="Black">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="29" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#000D14">
                <buttons:ButtonTaskbar Width="30"
                                       Height="30"
                                       FontSize="20"
                                       WindowChrome.IsHitTestVisibleInChrome="True"
                                       HorizontalAlignment="Right"
                                       ColorBrush="#ff000f"
                                       Content="X"
                                       Padding="1"
                                       Click="ExitButtonClick" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="5">
                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Scene item name: " />
                        <Run Text="{Binding SceneItemViewModel.SourceName, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>

                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Group name: " />
                        <Run Text="{Binding SceneItemViewModel.GroupName, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>

                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Base type: " />
                        <Run Text="{Binding SceneItemViewModel.BaseItemType, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>

                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Custom type: " />
                        <Run Text="{Binding SceneItemViewModel.InputKind, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Stretch">
                    <TextBlock Text="Binding configuration"
                               FontSize="22"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Background="Transparent"
                               Foreground="Wheat"
                               FontWeight="SemiBold"
                               Padding="0"
                               Margin="4" />
                    
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Left">
                        <!-- Trzeba dla kazdego comboxa dac textblock po -->
                        <ComboBox Style="{StaticResource ComboBoxTest2}"
                                  Width="200"
                                  Height="20"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding SupportedInputKinds}"
                                  SelectedItem="{Binding InputKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ComboBox Style="{StaticResource ComboBoxTest2}"
                                  Width="200"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding Schemas}"
                                  SelectedItem="{Binding ChosenSchema, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0 5 0 0" />

                        <ContentControl Content="{Binding BindingConfigurationViewModel}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>