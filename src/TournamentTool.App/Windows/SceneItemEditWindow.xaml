<Window x:Class="TournamentTool.App.Windows.SceneItemEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TournamentTool.App.Windows"
        xmlns:obs="clr-namespace:TournamentTool.ViewModels.Obs;assembly=TournamentTool.ViewModels"
        xmlns:buttons="clr-namespace:TournamentTool.App.Components.Buttons"
        xmlns:items="clr-namespace:TournamentTool.ViewModels.Obs.Items;assembly=TournamentTool.ViewModels"
        xmlns:obsDomain="clr-namespace:TournamentTool.Domain.Obs;assembly=TournamentTool.Domain"
        xmlns:converters="clr-namespace:TournamentTool.App.Converters"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:TournamentTool.App.Components.Behaviors"
        d:DataContext="{d:DesignInstance Type=obs:SceneItemEditWindowViewModel}"
        mc:Ignorable="d"
        Title="Scene item edit window"
        Height="450"
        Width="800"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        WindowStyle="None">
    <Window.Resources>

        <DataTemplate DataType="{x:Type items:PointOfViewViewModel}">
            <StackPanel>
                <TextBlock Text="Point of view" />
                <!-- TODO: TU TRZEBA USTALIC caly config dla pov'a, chyba w sumie tu nic nie bedzie xd-->

                <ComboBox Style="{StaticResource ComboBoxTest2}"
                          Width="200"
                          Margin="10 0 0 0"
                          ItemsSource="{Binding Source={x:Static obsDomain:InputKindSupportedGroupValues.Browser}}"
                          SelectedItem="{Binding DataContext.InputKind, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            </StackPanel>
        </DataTemplate>
        
        <!-- BOLI TU DUPLIKOWANIE -->
        <DataTemplate DataType="{x:Type items:BrowserItemViewModel}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Browser"
                           FontSize="22"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Background="Transparent"
                           Foreground="White"
                           Padding="0"
                           Margin="2" />
                
                <ComboBox Style="{StaticResource ComboBoxTest2}"
                          Width="200"
                          Margin="10 0 0 0"
                          ItemsSource="{Binding Source={x:Static obsDomain:InputKindSupportedGroupValues.Browser}}"
                          SelectedItem="{Binding DataContext.InputKind, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="150"
                              Margin="10 0 0 0"
                              ItemsSource="{Binding DataContext.Sources, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ChosenSource, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="150"
                              Margin="10 0 0 0"
                              ItemsSource="{Binding DataContext.Fields, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ChosenField, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Visibility="{Binding DataContext.IsUsingName, Converter={StaticResource BoolToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0 10 0 5">
                    
                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="150"
                              Margin="10 0 0 0"
                              ItemsSource="{Binding DataContext.PovNames, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.SourceName, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    
                    <TextBlock Text="Source name"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Binding source name (for multiple elements of same source, differencing only by source name like POV type)"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Visibility="{Binding DataContext.IsUsingIndex, Converter={StaticResource BoolToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0 10 0 5">
                    <TextBox TextWrapping="Wrap"
                             Width="120"
                             Height="20"
                             Text="{Binding DataContext.Index, RelativeSource={RelativeSource AncestorType=Window}}"
                             Background="#9E9E9E"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top">
                        <b:Interaction.Behaviors>
                            <behaviors:NumericTextBoxBehavior AllowNegative="False" />
                        </b:Interaction.Behaviors>
                    </TextBox>
                    <TextBlock Text="Position"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Binding position (for list/array of elements, 1-based indexing)"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- BOLI TU DUPLIKOWANIE -->
        <DataTemplate DataType="{x:Type items:TextItemViewModel}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Text"
                           FontSize="22"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Background="Transparent"
                           Foreground="White"
                           Padding="0"
                           Margin="2" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="150"
                              Margin="10 0 0 0"
                              ItemsSource="{Binding DataContext.Sources, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ChosenSource, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="150"
                              Margin="10 0 0 0"
                              ItemsSource="{Binding DataContext.Fields, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ChosenField, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Visibility="{Binding DataContext.IsUsingName, Converter={StaticResource BoolToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0 10 0 5">
                    
                    <ComboBox Style="{StaticResource ComboBoxTest2}"
                              Width="150"
                              Margin="10 0 0 0"
                              ItemsSource="{Binding DataContext.PovNames, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.SourceName, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    
                    <TextBlock Text="Source name"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Binding source name (for multiple elements of same source, differencing only by source name like POV type)"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Visibility="{Binding DataContext.IsUsingIndex, Converter={StaticResource BoolToVisibilityConverter}, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0 10 0 5">
                    <TextBox TextWrapping="Wrap"
                             Width="120"
                             Height="20"
                             Text="{Binding DataContext.Index, RelativeSource={RelativeSource AncestorType=Window}}"
                             Background="#9E9E9E"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top">
                        <b:Interaction.Behaviors>
                            <behaviors:NumericTextBoxBehavior AllowNegative="False" />
                        </b:Interaction.Behaviors>
                    </TextBox>
                    <TextBlock Text="Position"
                               ToolTipService.InitialShowDelay="0"
                               ToolTipService.ShowDuration="60000"
                               ToolTip="Binding position (for list/array of elements, 1-based indexing)"
                               Foreground="White"
                               Height="20"
                               FontSize="16"
                               Padding="0"
                               Margin="5 0 0 3" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <Border BorderThickness="1"
            BorderBrush="Black">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="29" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#000D14">
                <buttons:ButtonTaskbar Width="30"
                                       Height="30"
                                       FontSize="20"
                                       WindowChrome.IsHitTestVisibleInChrome="True"
                                       HorizontalAlignment="Right"
                                       ColorBrush="#ff000f"
                                       Content="X"
                                       Padding="1"
                                       Click="ExitButtonClick" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0"
                            Margin="5">
                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Scene item name: " />
                        <Run Text="{Binding SceneItemViewModel.SourceName, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>
                    
                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Group name: " />
                        <Run Text="{Binding SceneItemViewModel.GroupName, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>

                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Base type: " />
                        <Run Text="{Binding SceneItemViewModel.BaseItemType, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>
                    
                    <TextBlock FontSize="12"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Background="Transparent"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               Cursor="Hand"
                               Padding="0">

                        <Run Text="Custom type: " />
                        <Run Text="{Binding SceneItemViewModel.InputKind, Mode=OneWay}"
                             Foreground="Wheat" />
                    </TextBlock>
                </StackPanel>

                <Grid Grid.Column="1">
                    <ContentControl Content="{Binding SceneItemViewModel}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
