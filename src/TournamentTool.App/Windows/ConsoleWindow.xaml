<Window x:Class="TournamentTool.App.Windows.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:TournamentTool.App.Components.Controls"
        xmlns:buttons="clr-namespace:TournamentTool.App.Components.Buttons"
        xmlns:logging="clr-namespace:TournamentTool.ViewModels.Logging;assembly=TournamentTool.ViewModels"
        d:DataContext="{d:DesignInstance Type=logging:ConsoleWindowViewModel}"
        mc:Ignorable="d"
        Title="Console"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        MinHeight="450"
        MinWidth="800"
        Height="450"
        Width="800"
        Background="#0c0c0c">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      CaptionHeight="24"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="29" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#000000">
            <TextBlock Text="Console"
                       Foreground="White"
                       FontSize="22"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="5 0 0 0" />
            
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <buttons:ButtonTaskbar Width="30"
                                       Height="30"
                                       FontSize="17"
                                       WindowChrome.IsHitTestVisibleInChrome="True"
                                       Command="{Binding DataContext.BackToMainWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                       HorizontalAlignment="Right"
                                       ColorBrush="#1a1a1a"
                                       ToolTipService.InitialShowDelay="0"
                                       ToolTipService.ShowDuration="60000"
                                       ToolTip="Back to original window" >
                    <TextBlock Text="/\" Margin="0 -2 0 3"/>
                </buttons:ButtonTaskbar>

                <buttons:ButtonTaskbar Width="30"
                                       Height="30"
                                       FontSize="20"
                                       WindowChrome.IsHitTestVisibleInChrome="True"
                                       Command="{Binding DataContext.HideWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                       HorizontalAlignment="Right"
                                       ColorBrush="#ff000f"
                                       Content="X"
                                       Padding="1" />
            </StackPanel>
        </Grid>

        <controls:ConsoleLogsView Grid.Row="1"
                                  Background="Transparent"
                                  ItemsSource="{Binding Console.Logs}"
                                  Margin="2 0 0 0" />
    </Grid>
</Window>
