<Window x:Class="TournamentTool.App.Windows.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:buttons="clr-namespace:TournamentTool.App.Components.Buttons"
        xmlns:viewModels="clr-namespace:TournamentTool.ViewModels;assembly=TournamentTool.ViewModels"
        xmlns:series="clr-namespace:OxyPlot.Series;assembly=OxyPlot"
        d:DataContext="{d:DesignInstance Type=viewModels:DebugWindowViewModel}"
        mc:Ignorable="d"
        Title="DebugWindow"
        MinHeight="662"
        MinWidth="800"
        Height="662"
        Width="800"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Topmost="True"
        Background="#1E1E1E">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      CaptionHeight="24"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="450" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="29" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#000D14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Margin="5 0 0 0">
                    <TextBlock FontSize="22">
                        <Run Text="Selected:"
                             Foreground="White" />
                        <Run Text="{Binding SelectedViewModelName}"
                             Foreground="Cyan" />
                    </TextBlock>
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <buttons:ButtonTaskbar Width="30"
                                           Height="30"
                                           FontSize="20"
                                           WindowChrome.IsHitTestVisibleInChrome="True"
                                           HorizontalAlignment="Right"
                                           ColorBrush="#5a5d65"
                                           ContentText="-"
                                           Padding="2"
                                           Click="MinimizeButtonsClick" />
                    <buttons:ButtonTaskbar Width="30"
                                           Height="30"
                                           FontSize="20"
                                           WindowChrome.IsHitTestVisibleInChrome="True"
                                           HorizontalAlignment="Right"
                                           ColorBrush="#ff000f"
                                           ContentText="X"
                                           Padding="1"
                                           Click="ExitButtonClick" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <ListBox Background="Transparent"
                         Foreground="FloralWhite"
                         BorderThickness="0"
                         ItemsSource="{Binding Variables}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Focusable"
                                    Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Margin>
                                    <MultiBinding Converter="{StaticResource IndentConverter}">
                                        <Binding Path="IndentLevel" />
                                    </MultiBinding>
                                </StackPanel.Margin>
                                <Button Width="20"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Foreground="Cyan"
                                        FontSize="16"
                                        Padding="0 -5 2 0"
                                        Visibility="{Binding IsExpandable, Converter={StaticResource BoolToVisibilityConverterHidden}}"
                                        Content="{Binding IsExpanded, Converter={StaticResource ExpandCollapseConverter}}"
                                        Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}">
                                </Button>
                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                           Foreground="Wheat">
                                </TextBlock>
                                <TextBlock>
                                    <Run Text=":"
                                         Foreground="Wheat" />
                                    <Run Text="{Binding Value, Mode=OneWay}"
                                         Foreground="White" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!--<Grid Grid.Row="1">
            <oxy:PlotView Model="{Binding CpuPlotModel}"
                          Height="200"
                          Margin="10" />
        </Grid>-->
        
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding GeneralUsageInfo, Mode=OneWay}"
                       Foreground="White"
                       Margin="5 5 0 5" />

            <Border Grid.Row="1"
                    MinHeight="185"
                    Background="#1E1E1E"
                    BorderThickness="1"
                    BorderBrush="#3F3F3F">
                <DataGrid ItemsSource="{Binding ProfilingMethods}"
                          IsReadOnly="True"
                          Height="auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          Background="#1E1E1E"
                          Foreground="#E0E0E0"
                          BorderBrush="#3F3F3F"
                          AlternatingRowBackground="#2a2a2a">
                    <DataGrid.Resources>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Background"
                                    Value="#2D2D30" />
                            <Setter Property="Foreground"
                                    Value="#F1F1F1" />
                            <Setter Property="BorderBrush"
                                    Value="#3F3F3F" />
                            <Setter Property="BorderThickness"
                                    Value="0,0,1,1" />
                            <Setter Property="Padding"
                                    Value="8,4" />
                            <Setter Property="FontWeight"
                                    Value="SemiBold" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#3E3E42" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="{x:Type DataGridRow}">
                            <Setter Property="Background"
                                    Value="#252526" />
                            <Setter Property="Foreground"
                                    Value="#E0E0E0" />
                            <Setter Property="BorderThickness"
                                    Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#2A2A2D" />
                                </Trigger>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#094771" />
                                    <Setter Property="Foreground"
                                            Value="#FFFFFF" />
                                </Trigger>
                                <Trigger Property="AlternationIndex"
                                         Value="1">
                                    <Setter Property="Background"
                                            Value="#2D2D30" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="BorderBrush"
                                    Value="#3F3F3F" />
                            <Setter Property="BorderThickness"
                                    Value="0,0,1,1" />
                            <Setter Property="Padding"
                                    Value="4,2" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="Transparent" />
                                    <Setter Property="Foreground"
                                            Value="#FFFFFF" />
                                    <Setter Property="BorderBrush"
                                            Value="#3F3F3F" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding ClassName, Mode=OneWay}"
                                            Width="150" />
                        <DataGridTextColumn Header="Method"
                                            Binding="{Binding MethodName, Mode=OneWay}"
                                            Width="150" />
                        <DataGridTextColumn Header="Calls"
                                            Binding="{Binding CallCount, Mode=OneWay}"
                                            Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment"
                                            Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Last (ms)"
                                            Width="100"
                                            Binding="{Binding LastMilisecondsText, Mode=OneWay}"
                                            SortMemberPath="TotalMilliseconds">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment"
                                            Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Average (ms)"
                                            Binding="{Binding AverageMilisecondsText, Mode=OneWay}"
                                            Width="100"
                                            SortMemberPath="AverageMiliseconds">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment"
                                            Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Min (ms)"
                                            Binding="{Binding MinMilisecondsText, Mode=OneWay}"
                                            Width="80"
                                            SortMemberPath="MinMiliseconds">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment"
                                            Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Max (ms)"
                                            Binding="{Binding MaxMilisecondsText, Mode=OneWay}"
                                            Width="80"
                                            SortMemberPath="MaxMiliseconds">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment"
                                            Value="Right" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
