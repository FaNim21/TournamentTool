<Window x:Class="TournamentTool.App.Windows.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:modals="clr-namespace:TournamentTool.ViewModels.Modals;assembly=TournamentTool.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=modals:PopupWindowViewModel}"
        Width="120"
        Height="40"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#f2c63e"
        BorderThickness="0.75"
        BorderBrush="Black"
        AllowsTransparency="True"
        WindowStyle="None">
    <Grid>
        <TextBlock Text="{Binding Text, Mode=OneTime}"
                   TextWrapping="Wrap"
                   Foreground="Black"
                   FontSize="12" />
    </Grid>
</Window>
