<Weavers xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="FodyWeavers.xsd">
    <MethodBoundaryAspect>
        <IncludeNamespaces>
            TournamentTool.ViewModels.*
            TournamentTool.Services.*
            TournamentTool.Core.*
        </IncludeNamespaces>

        <ExcludeNamespaces>
            System.*
            Microsoft.*
            Windows.*
            TournamentTool.Services.Logging.*
        </ExcludeNamespaces>

        <ExcludeTypes>
            .*Converter$
            .*Extension$
            .*Helper$
        </ExcludeTypes>

        <ExcludeMethods>
            get_.*
            set_.*
            add_.*
            remove_.*
            .*_PropertyChanged
            \.ctor
            \.cctor
        </ExcludeMethods>

        <MethodFilters>
            <IncludeOnlyMethods>true</IncludeOnlyMethods>
            <ExcludeConstructors>true</ExcludeConstructors>
            <ExcludePropertyGetters>true</ExcludePropertyGetters>
            <ExcludePropertySetters>true</ExcludePropertySetters>
            <ExcludeEventAdders>true</ExcludeEventAdders>
            <ExcludeEventRemovers>true</ExcludeEventRemovers>
        </MethodFilters>
    </MethodBoundaryAspect>
</Weavers>